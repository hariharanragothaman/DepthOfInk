# DepthOfInk Backend — copy to .env and fill in

# Required: OpenAI API key (or key for compatible API)
OPENAI_API_KEY=sk-...

# Optional: use another API base (e.g. local LLM, OpenAI-compatible)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: override paths (defaults relative to backend/)
# DATA_DIR=data
# UPLOADS_DIR=data/uploads
# CHROMA_DIR=data/chroma

# Optional: models
# EMBEDDING_MODEL=text-embedding-3-small
# CHAT_MODEL=gpt-4o-mini

# Optional: RAG
# CHUNK_SIZE=800
# CHUNK_OVERLAP=150
# TOP_K_RETRIEVE=5
