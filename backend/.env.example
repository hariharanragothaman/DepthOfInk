# DepthOfInk Backend — copy to .env and fill in

# --- LLM Provider ---
# Choose: "openai" (default) | "bedrock"
# "openai" also works for Ollama and any OpenAI-compatible API
# LLM_PROVIDER=openai

# --- OpenAI settings (used when LLM_PROVIDER=openai) ---
OPENAI_API_KEY=sk-...
# Optional: point to another OpenAI-compatible API (Ollama, vLLM, etc.)
# OPENAI_BASE_URL=http://localhost:11434/v1

# --- AWS Bedrock settings (used when LLM_PROVIDER=bedrock) ---
# Requires AWS credentials configured (env vars, ~/.aws/credentials, or IAM role)
# AWS_REGION=us-east-1
# CHAT_MODEL=us.anthropic.claude-3-5-haiku-20241022-v1:0
# EMBEDDING_MODEL=amazon.titan-embed-text-v2:0

# --- Model names (provider-specific) ---
# OpenAI defaults:
# CHAT_MODEL=gpt-4o-mini
# EMBEDDING_MODEL=text-embedding-3-small
#
# Bedrock examples:
# CHAT_MODEL=us.anthropic.claude-3-5-haiku-20241022-v1:0
# EMBEDDING_MODEL=amazon.titan-embed-text-v2:0
#
# Ollama examples (with OPENAI_BASE_URL=http://localhost:11434/v1):
# CHAT_MODEL=llama3
# EMBEDDING_MODEL=nomic-embed-text

# --- Paths (defaults relative to backend/) ---
# DATA_DIR=data
# UPLOADS_DIR=data/uploads
# CHROMA_DIR=data/chroma

# --- RAG tuning ---
# CHUNK_SIZE=800
# CHUNK_OVERLAP=150
# TOP_K_RETRIEVE=5
